---
import '@/styles/global.css';
import { Toaster } from '@/components/ui/sonner';
import Header from '@/components/header.astro';
import Footer from '@/components/footer.astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description = 'IFF Email Campaigns' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link
			rel="icon"
			type="image/png"
			href="/favicon.png"
		/>
		<meta
			name="viewport"
			content="width=device-width, initial-scale=1"
		/>
		<meta
			name="description"
			content={description}
		/>
		<meta
			name="generator"
			content={Astro.generator}
		/>
		<title>{title}</title>
	</head>
	<body class="bg-background min-h-screen font-sans antialiased">
		<div class="relative flex min-h-screen flex-col">
			<Header />
			<main class="flex-1">
				<slot />
			</main>
			<Footer />
		</div>
		<Toaster
			client:load
			richColors
			position="top-right"
		/>
	</body>
</html>
