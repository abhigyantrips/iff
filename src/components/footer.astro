---
import {
  RedditLogoIcon,
  InstagramLogoIcon,
  XLogoIcon,
  LinkedinLogoIcon,
  MastodonLogoIcon,
  YoutubeLogoIcon,
  RssIcon,
} from '@phosphor-icons/react';

const socialLinks = [
  {
    icon: RedditLogoIcon,
    href: 'https://www.reddit.com/user/InternetFreedomIn',
    label: 'Reddit',
  },
  {
    icon: InstagramLogoIcon,
    href: 'https://instagram.com/internetfreedom.in',
    label: 'Instagram',
  },
  {
    icon: XLogoIcon,
    href: 'https://x.com/internetfreedom',
    label: 'X (Twitter)',
  },
  {
    icon: LinkedinLogoIcon,
    href: 'https://linkedin.com/company/internet-freedom-foundation',
    label: 'LinkedIn',
  },
  {
    icon: MastodonLogoIcon,
    href: 'https://mas.to/@internetfreedom',
    label: 'Mastodon',
  },
  {
    icon: YoutubeLogoIcon,
    href: 'https://youtube.com/@internetfreedomfoundation',
    label: 'YouTube',
  },
  { icon: RssIcon, href: 'https://internetfreedom.in/rss', label: 'RSS Feed' },
];
---

<footer class="w-full" style="background-color: rgb(23, 23, 23);">
  <div class="container mx-auto px-4 py-10">
    <div class="flex flex-col items-center gap-6">
      <nav class="flex items-center gap-5">
        {
          socialLinks.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.label}
              class="text-gray-400 transition-colors hover:text-white"
            >
              <social.icon className="size-6" weight="fill" />
            </a>
          ))
        }
      </nav>

      <a
        href="https://internetfreedom.in/privacy-policy"
        class="text-sm text-gray-400 transition-colors hover:text-white"
      >
        Privacy Policy
      </a>

      <div class="text-center">
        <p class="text-sm font-medium text-gray-300">
          © Internet Freedom Foundation
        </p>
        <p class="mt-1 text-sm text-gray-500">
          All contents licensed under CC-BY unless stated otherwise.
        </p>
      </div>
    </div>
  </div>
</footer>
