---
import { AuthButton } from '@/components/auth-button';
---

<div class="w-full bg-amber-500 text-zinc-900">
  <div class="mx-auto px-4 py-2 text-center text-xs font-medium">
    <span class="inline-block">
      This is an independent concept project and is not affiliated with,
      endorsed by, or officially connected to the
      <a
        href="https://internetfreedom.in"
        target="_blank"
        rel="noopener noreferrer"
        class="font-semibold underline hover:no-underline"
      >
        Internet Freedom Foundation
      </a>. All trademarks, logos, and brand assets displayed belong to their
      respective owners.
    </span>
  </div>
</div>
<header
  class="sticky top-0 z-50 w-full"
  style="background-color: rgb(23, 23, 23);"
>
  <div class="container mx-auto flex h-16 items-center justify-between px-4">
    <div class="flex items-center gap-8">
      <a href="/admin/campaigns" class="flex items-center gap-3">
        <img
          src="/logo.svg"
          alt="Internet Freedom Foundation"
          class="h-10 w-auto"
        />
      </a>
      <nav class="flex items-center gap-6">
        <a
          href="/admin/campaigns"
          class="text-sm font-medium text-gray-300 transition-colors hover:text-white"
        >
          Campaigns
        </a>
      </nav>
    </div>

    <div class="flex items-center">
      <AuthButton client:load />
    </div>
  </div>
</header>
